---
import TeletextScreen from '@components/TeletextScreen.astro';
import BroadcastHeader from '@components/BroadcastHeader.astro';
import FooterControls from '@components/FooterControls.astro';
---
<TeletextScreen title="MARCUS HARTELT — LEGAL P900">
  <BroadcastHeader pageCode="P900/01" center="LEGAL / SITE INFO" />
  <div class="teletext-divider"></div>

  <h1 class="page-title">LEGAL / SITE INFO</h1>
  <p class="status-line">IMPRINT / PRIVACY POLICY</p>

  <div class="about-layout legal-overview-about-layout" style="margin-top:18px">
    <div>
      <div class="about-role">MARCUSHARTELT.COM</div>
      <div class="teletext-divider teletext-divider--dotted-magenta"></div>

      <p class="about-text">
        This section contains the legal information for marcushartelt.com.
      </p>
      <p class="about-text">
        The Imprint includes operator details, contact information, copyright
        notes, liability information and the notice about unsolicited contact.
      </p>
      <p class="about-text">
        The Privacy Policy explains how this static portfolio website handles
        privacy, hosting, voluntary contact and GDPR rights.
      </p>

      <div class="discipline-list legal-document-list" style="margin-top:18px">
        <a class="disc-item legal-document-link" href="/impressum">
          <span class="disc-code">901</span>IMPRINT
        </a>
        <a class="disc-item legal-document-link" href="/privacy">
          <span class="disc-code">902</span>PRIVACY POLICY
        </a>
      </div>
    </div>

    <aside class="legal-overview-aside">
      <div class="about-meta-row"><span class="c-white">SITE</span><span class="c-yellow">MARCUSHARTELT.COM</span></div>
      <div class="about-meta-row"><span class="c-white">DOCUMENTS</span><span class="c-cyan">2</span></div>
      <div class="about-meta-row"><span class="c-white">IMPRINT</span><span class="c-magenta">P901</span></div>
      <div class="about-meta-row"><span class="c-white">PRIVACY</span><span class="c-green">P902</span></div>
    </aside>
  </div>

  <FooterControls />
</TeletextScreen>
