---
import '@styles/global.css';
import { inject } from '@vercel/analytics';
const { title = 'Marcus Hartelt', home = false, screenClass = '' } = Astro.props;
inject();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, viewport-fit=cover" />
    <meta name="description" content="Marcus Hartelt photography portfolio in a teletext broadcast gallery design." />
    <title>{title}</title>
  </head>
  <body id="top" class="teletext-page">
    <div class="teletext-stage">
      <main class:list={[
        "teletext-screen",
        "font-teletext50",
        "",
        "crt-glow-only",
        home && "teletext-screen--home",
        screenClass
      ]}>
        <slot />
      </main>
    </div>

    <script type="module" src="/scripts/navigation.js"></script>
  </body>
</html>
